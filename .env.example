# ─────────────────────────────────────────────────────────────
# Studfy — Environment Variables (örnek). Kopyala: cp .env.example .env
# ASLA gerçek secret'ları commit etme. .env, .gitignore'dadır.
# ─────────────────────────────────────────────────────────────

# --- General ---
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=debug

# --- PostgreSQL (pgvector) ---
POSTGRES_USER=studfy
POSTGRES_PASSWORD=studfy_dev_password
POSTGRES_DB=studfy
DATABASE_URL=postgresql://studfy:studfy_dev_password@localhost:5432/studfy?schema=public

# --- Redis (cache + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Qdrant (vector store; MVP'de pgvector yeterli) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Object Storage (Cloudflare R2 / S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=studfy-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Auth ---
AUTH_SECRET=change_me_generate_a_long_random_string
AUTH_URL=http://localhost:3000
# OAuth (opsiyonel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM Gateway (LiteLLM) ---
LITELLM_BASE_URL=http://localhost:4000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Model yönlendirme (varsayılanlar; güncel model ID'lerini Claude API referansından doğrula)
LLM_REASONING_MODEL=claude-sonnet
LLM_CHEAP_MODEL=gemini-flash
LLM_VISION_MODEL=gpt-4o
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda

# --- TTS ---
TTS_PROVIDER=openai
ELEVENLABS_API_KEY=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# --- KMS (envelope encryption) ---
KMS_PROVIDER=local
KMS_MASTER_KEY=dev_only_local_master_key_change_in_prod

# --- Fair-use kotaları ---
FREE_TIER_MONTHLY_AI_TOKENS=2000000
FREE_TIER_MAX_UPLOAD_MB=200

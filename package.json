{
  "name": "studfy",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native Öğrenme İşletim Sistemi — multimodal upload, zero-hallucination RAG, interaktif test, spaced repetition.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "db:migrate": "pnpm --filter @studfy/api prisma migrate dev",
    "db:generate": "pnpm --filter @studfy/api prisma generate",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@studfy/config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^6.0.3"
  }
}
